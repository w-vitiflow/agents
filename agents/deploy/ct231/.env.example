# Copy to /root/hermes/.env (ERP hermes) or export before docker compose.
# Never commit filled-in values.

# --- ERP hermes (.env) ---
# OPENROUTER_API_KEY=
# TELEGRAM_BOT_TOKEN=

# --- hermes-grok (compose environment or .env.grok) ---
HERMES_GROK_DASHBOARD_PASSWORD=change-me
API_SERVER_KEY=change-me-min-8-chars
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=8454262747,8851361101
TELEGRAM_ALLOWED_CHATS=-1004284511728

# xAI OAuth and OpenRouter fallbacks are stored in /root/.hermes-grok/auth.json
# and configured via `hermes auth` — not in this file.